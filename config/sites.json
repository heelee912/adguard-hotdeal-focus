    {
      "id": "clien",
      "name": "Clien",
      "layouts": [
        {
          "id": "jirum",
          "domain": "clien.net",
          "path": "|/service/board/jirum/",
          "applicable_profiles": [
            "desktop",
            "mobile"
          ],
          "page_root": ".content_view",
          "sample_urls": [
            "https://www.clien.net/service/board/jirum/19230509"
          ],
          "ancestor_markers": [
            ".post_subject",
            ".post_article",
            ".post_comment",
            ".post_comment > .comment"
          ],
          "preserve_deep": [
            ".post_article",
            ".post_comment > .comment"
          ],
          "preserve_shallow": [
            ".post_subject",
            ".post_comment"
          ],
          "required_roles": [
            "title",
            "body",
            "comments"
          ],
          "required_groups": {
            "title": [
              ".post_subject"
            ],
            "body": [
              ".post_article"
            ],
            "comments": [
              ".post_comment"
            ]
          },
          "role_projection": {
            "title": { "mode": "seeded-shallow" },
            "body": { "mode": "atomic-boundary", "ignored": [] },
            "product": {
              "mode": "absent",
              "cardinality": "zero",
              "selectors": [],
              "ignored": []
            },
            "comments": { "mode": "classified-children" }
          },
          "comment_contract": {
            "mount": [
              ".post_comment"
            ],
            "items": [
              ".post_comment > .comment .comment_row"
            ],
            "controls": [
              ".post_comment > .comment_nav",
              ".post_comment .comment_more",
              ".post_comment .pagination",
              ".post_comment [data-role='reply-toggle']"
            ],
            "ignored": [
              ".post_comment > .comment_head",
              ".post_comment > .comment_msg",
              ".post_comment > #comment_write_div",
              ".post_comment > .fr-overlay"
            ],
            "allow_empty": true
          }
        }
      ]
    },
